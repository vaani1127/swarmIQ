# Azure OpenAI — https://portal.azure.com → your Azure OpenAI resource
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_DEPLOYMENT_NAME=your_deployment_name_here   # e.g. gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01                      # or latest GA version

# Tavily web search — https://app.tavily.com (free, 1000 searches/mo)
TAVILY_API_KEY=your_tavily_key_here

# Redis — session state and 24-hour result cache (docker-compose sets this automatically)
REDIS_URL=redis://localhost:6379

# Microsoft Entra External ID — https://portal.azure.com → Microsoft Entra ID → App registrations
# Leave blank to disable authentication (app still works fully as anonymous)
AZURE_AD_TENANT_ID=your_tenant_id_here          # e.g. xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_AD_CLIENT_ID=your_client_id_here          # App (client) ID from the app registration
AZURE_AD_CLIENT_SECRET=your_client_secret_here  # Client secret (used for server-side validation)

# Azure Cosmos DB — MongoDB-compatible API
# https://portal.azure.com → Azure Cosmos DB → your account → Connection strings → Primary Connection String
# Leave blank to disable history storage (analyses will not be persisted)
COSMOS_DB_CONNECTION_STRING=mongodb://your-account:your-key@your-account.mongo.cosmos.azure.com:10255/?ssl=true&replicaSet=globaldb&retrywrites=false
COSMOS_DB_DATABASE_NAME=swarmiq
