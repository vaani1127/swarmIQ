# ── LLM inference ─────────────────────────────────────────────────────────────
# Provider-agnostic. Defaults below point at GitHub Models (free tier, Microsoft-hosted,
# OpenAI-compatible). Generate a GitHub PAT with models:read scope at:
#   https://github.com/settings/tokens?type=beta
LLM_BASE_URL=https://models.github.ai/inference
LLM_API_KEY=github_pat_your_token_here
LLM_MODEL=openai/gpt-4o-mini

# Optional alias — some workflows expect the GitHub-native env var name.
# If LLM_API_KEY is unset, the app falls back to GITHUB_TOKEN.
# GITHUB_TOKEN=github_pat_your_token_here

# ── To use Azure OpenAI instead (when you have quota) ────────────────────────
# LLM_BASE_URL=https://YOUR-RESOURCE.openai.azure.com/openai/v1
# LLM_API_KEY=your_azure_openai_api_key_here
# LLM_MODEL=your-deployment-name

# ── Tavily web search ─────────────────────────────────────────────────────────
# https://app.tavily.com (free, 1000 searches/mo)
TAVILY_API_KEY=your_tavily_key_here

# ── Redis ─────────────────────────────────────────────────────────────────────
# Session state and 24-hour result cache. docker-compose sets this automatically.
REDIS_URL=redis://localhost:6379

# ── Microsoft Entra External ID (optional — leave blank to disable auth) ─────
# https://portal.azure.com → Microsoft Entra ID → App registrations
AZURE_AD_TENANT_ID=your_tenant_id_here
AZURE_AD_CLIENT_ID=your_client_id_here
AZURE_AD_CLIENT_SECRET=your_client_secret_here  # Not read by the app — backend uses PKCE public-client flow. Safe to leave blank.

# ── Azure Cosmos DB (optional — leave blank to fall back to localStorage) ────
# https://portal.azure.com → Azure Cosmos DB → Connection strings → Primary
COSMOS_DB_CONNECTION_STRING=mongodb://your-account:your-key@your-account.mongo.cosmos.azure.com:10255/?ssl=true&replicaSet=globaldb&retrywrites=false
COSMOS_DB_DATABASE_NAME=swarmiq

# ── Email delivery (optional — used only by the "Email me the report" button) ─
# Gmail with App Password recommended. Create one at:
#   https://myaccount.google.com/apppasswords (2FA must be on)
MAIL_ID=swarmiq.reports@gmail.com
MAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx   # 16-char Gmail app password, NOT account password
MAIL_FROM_NAME=SwarmIQ
